# Copy to .env and fill in real values.

# Postgres/MySQL connection string Prisma introspects (`npm run prisma:pull`).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# bcrypt hash of the admin password. Generate with: npm run hash-password -- "your-password"
ADMIN_PASSWORD_HASH=

# Long random string used to sign session cookies.
SESSION_SECRET=

# Port the Express API/server listens on.
PORT=3001
